# .env.example - Copia este archivo como .env.local y completa los valores
# NUNCA subas el archivo .env.local a GitHub (está en .gitignore)

# Azure AD App Registration
VITE_CLIENT_ID=19db86c3-b2b9-44cc-b339-36da233a3be2
VITE_TENANT_ID=799ec06b-11b6-4308-90e0-8d75e21b0111

# URL de tu app en GitHub Pages (o localhost para dev)
VITE_REDIRECT_URI=https://TU_USUARIO.github.io/TU_REPO/

# SharePoint / Microsoft Graph
# Obtener siteId: GET https://graph.microsoft.com/v1.0/sites/{dominio}.sharepoint.com:/sites/{nombre-sitio}
VITE_SHAREPOINT_SITE_ID=https://bsolbo.sharepoint.com/sites/QA_CreditosDigital/Shared%20Documents/Forms/AllItems.aspx?id=%2Fsites%2FQA%5FCreditosDigital%2FShared%20Documents%2FGeneral&viewid=1b85d779%2D5b13%2D4bb8%2Db2c0%2D0e3dae5071cd

# Obtener fileId: GET https://graph.microsoft.com/v1.0/sites/{siteId}/drive/root/children
VITE_EXCEL_FILE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx!xxxx
